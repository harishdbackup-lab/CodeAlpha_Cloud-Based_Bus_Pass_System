# Database Configuration
DATABASE_URL=sqlite:///bus_pass.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@host:5432/bus_pass

# JWT Configuration
JWT_SECRET_KEY=bus_system_secret_key_2024

# Admin Configuration
ADMIN_KEY=admin_secret_2024

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Payment Gateway Configuration
PAYMENT_GATEWAY_KEY=your_payment_gateway_key
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret

# AWS Configuration (for S3 storage, if needed)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=bus-pass-tickets

# Application Configuration
APP_NAME=Cloud-Based Bus Pass System
MAX_PASSENGERS_PER_BOOKING=6
BOOKING_EXPIRY_MINUTES=10
CANCELLATION_CHARGE_PERCENTAGE=10
